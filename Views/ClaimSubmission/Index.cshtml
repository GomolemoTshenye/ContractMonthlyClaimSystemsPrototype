@model ContractMonthlyClaimSystemsPrototype.Models.Claim

@{
    ViewBag.Title = "Submit Claim";
}

<div class="card shadow">
    <div class="card-header bg-primary text-white">
        <h2>Lecturer Claim Form</h2>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Index", "ClaimSubmission", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-horizontal">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">For Month</label>
                        @Html.DropDownListFor(model => model.Month, (SelectList)ViewBag.Months, "Select Month", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.Month, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Upload Document</label>
                        <input type="file" name="upload" class="form-control" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Hours Worked</label>
                        @Html.EditorFor(model => model.HoursWorked, new { htmlAttributes = new { @class = "form-control", @id = "txtHours" } })
                        @Html.ValidationMessageFor(model => model.HoursWorked, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Hourly Rate (R)</label>
                        @Html.EditorFor(model => model.HourlyRate, new { htmlAttributes = new { @class = "form-control", @id = "txtRate" } })
                        @Html.ValidationMessageFor(model => model.HourlyRate, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Total (Auto-Calculated)</label>
                        <input type="text" id="txtTotal" class="form-control bg-light" readonly value="R 0.00" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Additional Notes</label>
                    @Html.TextAreaFor(model => model.AdditionalNotes, new { @class = "form-control", rows = "3" })
                </div>

                <button type="submit" class="btn btn-success btn-lg">Submit Claim</button>
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        // AUTOMATION: Client-side real-time calculation
        $(document).ready(function () {
            function calculate() {
                var hours = parseFloat($("#txtHours").val()) || 0;
                var rate = parseFloat($("#txtRate").val()) || 0;
                var total = hours * rate;
                $("#txtTotal").val("R " + total.toFixed(2));
            }

            $("#txtHours, #txtRate").on("keyup change", calculate);
        });
    </script>
}