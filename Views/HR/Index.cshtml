@model IEnumerable<ContractMonthlyClaimSystemsPrototype.Models.Claim>

@{
    ViewBag.Title = "HR View";
}

<h2>HR Management</h2>
<p>Generate invoices for approved claims.</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Claim ID</th>
            <th>Lecturer</th>
            <th>Total Pay</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.LecturerId</td>
                <td class="fw-bold text-success">R @item.Amount</td>
                <td><span class="badge bg-success">Approved</span></td>
                <td>
                    @Html.ActionLink("Generate Invoice", "GenerateInvoice", new { id = item.Id }, new { @class = "btn btn-primary" })
                </td>
            </tr>
        }
    </tbody>
</table>