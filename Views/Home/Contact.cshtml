@{
    ViewBag.Title = "Contact Support";
}

<main aria-labelledby="title" class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 id="title" class="border-bottom pb-2">@ViewBag.Title</h2>
            <p class="lead text-muted">Get in touch with the relevant department for assistance with your claims.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="card-title text-primary">Technical Support</h4>
                    <p class="card-text">For issues regarding login, file uploads, or system errors.</p>
                    <hr />
                    <address>
                        <strong>Email:</strong> <a href="mailto:ITSupport@university.ac.za">ITSupport@university.ac.za</a><br />
                        <strong>Phone:</strong> +27 11 555 0100<br />
                        <strong>Hours:</strong> Mon-Fri, 08:00 - 17:00
                    </address>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="card-title text-success">HR & Payroll</h4>
                    <p class="card-text">For enquiries regarding payment dates, rates, and contract details.</p>
                    <hr />
                    <address>
                        <strong>Email:</strong> <a href="mailto:Payroll@university.ac.za">Payroll@university.ac.za</a><br />
                        <strong>Phone:</strong> +27 11 555 0200<br />
                        <strong>Location:</strong> Admin Building, Block B, Room 102
                    </address>
                </div>
            </div>
        </div>
    </div>
</main>